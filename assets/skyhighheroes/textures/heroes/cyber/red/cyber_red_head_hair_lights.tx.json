{
  "texture": {
    "in": "skyhighheroes:cyber/red/cyber_red_lights",
    "transform": [
      {
        "operation": "XOR",
        "supply": "skyhighheroes:xor/cybernetic_thermoptic<SWITCH>_<TIMER>"
      },
      {
        "operation": "STITCH",
        "supply": "skyhighheroes:cybernetic_head_hair"
      }
    ],
    "out": "skyhighheroes:generated/cyber_red_head_hair_lights<SWITCH>_<TIMER>"
  },
  "getters": {
    "TIMER": {
      "key": "Math.min(Math.max(Math.ceil(47*(((!entity.getData('skyhighheroes:dyn/thermoptic_disguise') ? -1 : 1) * entity.getInterpolatedData('skyhighheroes:dyn/thermoptic_disguise_timer') + (!entity.getData('skyhighheroes:dyn/thermoptic_disguise') ? 1 : 0)) - ((entity.getData('skyhighheroes:dyn/thermoptic_camouflage') ? -1 : 1) * entity.getInterpolatedData('skyhighheroes:dyn/thermoptic_camouflage_timer') + (entity.getData('skyhighheroes:dyn/thermoptic_camouflage') ? 1 : 0)))), 0), 15) | 0",
      "values": {
        "min": 0,
        "max": 15
      }
    },
    "SWITCH": {
      "key": "entity.getInterpolatedData('skyhighheroes:dyn/thermoptic_disguise') || entity.getInterpolatedData('skyhighheroes:dyn/thermoptic_camouflage') ? '_base' : ''",
      "values": ["", "_base"]
    }
  },
  "isDynamic": true
}