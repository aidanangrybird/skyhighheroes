{vel} = sqrt({motX}^2 + {motZ}^2)
{dir} = sqrt({lookX}^2 + {lookZ}^2)

{cosa} = cos({bodyYaw}')
{sina} = sin({bodyYaw}')
{strafe} = clamp({motX}{cosa} + {motZ}{sina}, -0.5, 0.5)
{forward} = clamp({motZ}{cosa} - {motX}{sina}, -1, 1)

{hover} = {data_13}(1 - {data_14})
{x} = {hover}min(2{vel}, 1)
{strafe} *= {x}
{forward} *= {x}
{ahead} = abs clamp({forward}, 0, 1)
{reverse} = abs clamp({forward}, -1, 0)
{left_strafe} = abs clamp({strafe}, 0, 0.5)
{right_strafe} = abs clamp({strafe}, -0.5, 0)
{adx} = abs {strafe}
{adz} = abs {forward}

{main_cannon} = curve(clamp({data_0}, 0, 1))
{front_cannon} = curve(clamp({data_1}, 0, 1))
{back_cannon} = curve(clamp({data_2}, 0, 1))
{outer_rocket} = curve(clamp({data_3}, 0, 1))
{front_rocket} = curve(clamp({data_4}, 0, 1))
{back_rocket} = curve(clamp({data_5}, 0, 1))
{blade} = curve(clamp({data_6}, 0, 1))
{shield} = curve(clamp({data_7}, 0, 1))
{blade_stealth} = curve(clamp({data_8}, 0, 1))
{cannon_flush} = curve(clamp({data_9}, 0, 1))
{intake} = curve(clamp({data_10}, 0, 1))
{spin} = {data_11}*2
{mot_Z} = if({data_12}>0, 1, {motZ})

;cannons
;main
{part0_main_cannon} = if({main_cannon} != 1, animate2({cannon}, 1.0, 0.0, 0.15, 0.0), 1)
{part1_main_cannon} = if({main_cannon} != 1, animate2({main_cannon}, 1.0, 0.2, 0.2, 0.0), 1)
{part2_main_cannon} = if({main_cannon} != 1, animate2({main_cannon}, 1.0, 0.6, 0.4, 0.0), 1)
{right_arm_outer_main_cannon_cover_posY} -= 0.03{part0_main_cannon}
{right_arm_inner_main_cannon_cover_posY} -= 0.03{part0_main_cannon}
{right_arm_outer_main_cannon_cover_posX} -= 0.99{part1_main_cannon} + 0.01{part0_main_cannon}
{right_arm_inner_main_cannon_cover_posX} += 0.99{part1_main_cannon} + 0.01{part0_main_cannon}
{right_arm_main_cannon_posY} += 3{part2_main_cannon} - 2.9{part2_main_cannon}{cannon_flush}
;front
{part0_front_cannon} = if({front_cannon} != 1, animate2({front_cannon}, 1.0, 0.0, 0.15, 0.0), 1)
{part1_front_cannon} = if({front_cannon} != 1, animate2({front_cannon}, 1.0, 0.2, 0.2, 0.0), 1)
{part2_front_cannon} = if({front_cannon} != 1, animate2({front_cannon}, 1.0, 0.6, 0.4, 0.0), 1)
{right_arm_outer_front_cannon_cover_posZ} += 0.03{part0_front_cannon}
{right_arm_inner_front_cannon_cover_posZ} += 0.03{part0_front_cannon}
{right_arm_outer_front_cannon_cover_posX} -= 0.99{part1_front_cannon} + 0.01{part0_front_cannon}
{right_arm_inner_front_cannon_cover_posX} += 0.99{part1_front_cannon} + 0.01{part0_front_cannon}
{right_arm_front_cannon_posZ} -= 2.9{part2_front_cannon} - 0.8{part2_front_cannon}{cannon_flush}
;back
{part0_back_cannon} = if({back_cannon} != 1, animate2({back_cannon}, 1.0, 0.0, 0.15, 0.0), 1)
{part1_back_cannon} = if({back_cannon} != 1, animate2({back_cannon}, 1.0, 0.2, 0.2, 0.0), 1)
{part2_back_cannon} = if({back_cannon} != 1, animate2({back_cannon}, 1.0, 0.6, 0.4, 0.0), 1)
{right_arm_outer_back_cannon_cover_posZ} -= 0.03{part0_back_cannon}
{right_arm_inner_back_cannon_cover_posZ} -= 0.03{part0_back_cannon}
{right_arm_outer_back_cannon_cover_posX} -= 0.99{part1_back_cannon} + 0.01{part0_back_cannon}
{right_arm_inner_back_cannon_cover_posX} += 0.99{part1_back_cannon} + 0.01{part0_back_cannon}
{right_arm_back_cannon_posZ} += 2.9{part2_back_cannon} - 0.8{part2_back_cannon}{cannon_flush}

;rockets
;outer
{part0_outer_rocket} = if({outer_rocket} != 1, animate2({outer_rocket}, 1.0, 0.0, 0.15, 0.0), 1)
{part1_outer_rocket} = if({outer_rocket} != 1, animate2({outer_rocket}, 1.0, 0.2, 0.1, 0.0), 1)
{part2_outer_rocket} = if({outer_rocket} != 1, animate2({outer_rocket}, 1.0, 0.3, 0.1, 0.0), 1)
{part3_outer_rocket} = if({outer_rocket} != 1, animate2({outer_rocket}, 1.0, 0.4, 0.2, 0.0), 1)
{part4_outer_rocket} = if({outer_rocket} != 1, animate2({outer_rocket}, 1.0, 0.6, 0.4, 0.0), 1)
{right_arm_front_outer_rocket_cover_posX} += 0.03{part0_outer_rocket}
{right_arm_back_outer_rocket_cover_posX} += 0.03{part0_outer_rocket}
{right_arm_front_outer_rocket_cover_posZ} -= 0.99{part1_outer_rocket} + 0.01{part0_outer_rocket}
{right_arm_back_outer_rocket_cover_posZ} += 0.99{part1_outer_rocket} + 0.01{part0_outer_rocket}
{right_arm_outer_rocket_base_posX} -= 2.9{part2_outer_rocket}
{right_arm_outer_rocket_rotX} += 90'{part3_outer_rocket} - 45'{part3_outer_rocket}{adx}
{right_arm_outer_rocket_rotY} -= 45'{part3_outer_rocket}{forward} + 45'{part3_outer_rocket}{mot_Z}

;front
{part0_front_rocket} = if({front_rocket} != 1, animate2({front_rocket}, 1.0, 0.0, 0.15, 0.0), 1)
{part1_front_rocket} = if({front_rocket} != 1, animate2({front_rocket}, 1.0, 0.2, 0.1, 0.0), 1)
{part2_front_rocket} = if({front_rocket} != 1, animate2({front_rocket}, 1.0, 0.3, 0.1, 0.0), 1)
{part3_front_rocket} = if({front_rocket} != 1, animate2({front_rocket}, 1.0, 0.4, 0.2, 0.0), 1)
{part4_front_rocket} = if({front_rocket} != 1, animate2({front_rocket}, 1.0, 0.6, 0.4, 0.0), 1)
{right_arm_outer_front_rocket_cover_posZ} += 0.03{part0_front_rocket}
{right_arm_inner_front_rocket_cover_posX} -= 0.02{part0_front_rocket}
{right_arm_outer_front_rocket_cover_posX} -= 0.99{part2_front_rocket} + 0.01{part0_front_rocket}
{right_arm_inner_front_rocket_cover_posZ} -= 0.99{part1_front_rocket} + 0.01{part0_front_rocket}
{right_arm_outer_front_rocket_cover_posY} -= 0.99{part2_front_rocket} + 0.01{part0_front_rocket}
{right_arm_inner_front_rocket_cover_posY} -= 0.99{part1_front_rocket} + 0.01{part0_front_rocket}
{right_arm_front_rocket_base_posZ} -= 2.9{part3_front_rocket}
{right_arm_front_rocket_rotX} += 90'{part3_front_rocket} - 45'{part3_front_rocket}{adz} - 45'{part3_front_rocket}{mot_Z}
{right_arm_front_rocket_rotY} -= 90'{part3_front_rocket}{strafe}

;back
{part0_back_rocket} = if({back_rocket} != 1, animate2({back_rocket}, 1.0, 0.0, 0.15, 0.0), 1)
{part1_back_rocket} = if({back_rocket} != 1, animate2({back_rocket}, 1.0, 0.2, 0.1, 0.0), 1)
{part2_back_rocket} = if({back_rocket} != 1, animate2({back_rocket}, 1.0, 0.3, 0.1, 0.0), 1)
