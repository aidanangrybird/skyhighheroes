{right_arm_outer_back_rocket_cover_posX} -= 0.99{part2_back_rocket} + 0.01{part0_back_rocket}
{right_arm_inner_back_rocket_cover_posZ} += 0.99{part1_back_rocket} + 0.01{part0_back_rocket}
{right_arm_outer_back_rocket_cover_posY} -= 0.99{part2_back_rocket} + 0.01{part0_back_rocket}
{right_arm_inner_back_rocket_cover_posY} -= 0.99{part1_back_rocket} + 0.01{part0_back_rocket}
{right_arm_back_rocket_base_posZ} += 2.9{part3_back_rocket}
{right_arm_back_rocket_rotX} += 90'{part3_back_rocket} - 45'{part3_back_rocket}{adz} - 45'{part3_back_rocket}{mot_Z}
{right_arm_back_rocket_rotY} += 90'{part3_back_rocket}{strafe}

;blade
;main
{part0_blade} = if({blade} != 1, animate2({blade}, 1.0, 0.0, 0.15, 0.0), 1)
{part1_blade} = if({blade} != 1, animate2({blade}, 1.0, 0.2, 0.2, 0.0), 1)
{part2_blade} = if({blade} != 1, animate2({blade}, 1.0, 0.4, 0.2, 0.0), 1)
